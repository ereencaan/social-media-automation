# OpenAI (DALL-E 3 image generation)
OPENAI_API_KEY=

# Anthropic (Claude - caption & hashtag generation, multi-model review)
ANTHROPIC_API_KEY=

# Google Gemini (multi-model review — content critique, email review)
GEMINI_API_KEY=

# Google Drive (service account JSON key file path)
GOOGLE_SERVICE_ACCOUNT_KEY=./config/google-service-account.json

# Meta (Instagram + Facebook)
META_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
FACEBOOK_PAGE_ID=

# LinkedIn
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_ID=

# Cloudinary (permanent media hosting)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Flux / BFL (image generation alternative)
BFL_API_KEY=

# Runway (video generation)
RUNWAY_API_KEY=

# Templated.io (template-based rendering)
TEMPLATED_API_KEY=

# Server
PORT=3000

# Session (auth) - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-in-production

# Off-VM backup target for scripts/backup-db.sh (rclone remote path).
# Leave empty to keep backups local-only. See docs/RESTORE.md to set up R2/B2.
#   e.g. r2:hitrapost-backups/posts-db
BACKUP_RCLONE_REMOTE=
# Daily-snapshot retention on the remote (rclone duration syntax). Default 30d.
BACKUP_RCLONE_RETENTION=30d
