# OpenAI (DALL-E 3 image generation)
OPENAI_API_KEY=

# Anthropic (Claude - caption & hashtag generation, multi-model review)
ANTHROPIC_API_KEY=

# Google Gemini (multi-model review — content critique, email review)
GEMINI_API_KEY=

# Google Drive (service account JSON key file path)
GOOGLE_SERVICE_ACCOUNT_KEY=./config/google-service-account.json

# Meta (Instagram + Facebook)
META_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
FACEBOOK_PAGE_ID=

# LinkedIn
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_ID=

# Cloudinary (permanent media hosting)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Flux / BFL (image generation alternative)
BFL_API_KEY=

# Runway (video generation)
RUNWAY_API_KEY=

# Templated.io (template-based rendering)
TEMPLATED_API_KEY=

# Server
PORT=3000

# Session (auth) - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-in-production

# Off-VM backup target for scripts/backup-db.sh (rclone remote path).
# Leave empty to keep backups local-only. See docs/RESTORE.md to set up R2/B2.
#   e.g. r2:hitrapost-backups/posts-db
BACKUP_RCLONE_REMOTE=
# Daily-snapshot retention on the remote (rclone duration syntax). Default 30d.
BACKUP_RCLONE_RETENTION=30d

# Public base URL — used to build Stripe success/cancel redirect URLs and
# absolute links in emails. NO trailing slash.
PUBLIC_BASE_URL=https://hitrapost.co.uk

# Stripe billing — leave blank in dev/preview, the billing routes return 503.
# Once you create the products in Stripe Dashboard, paste the price IDs here.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_AGENCY_MONTHLY=
STRIPE_PRICE_AGENCY_YEARLY=

# Resend (transactional email — verification, password reset).
# Without RESEND_API_KEY, emails log to stdout instead of sending. That keeps
# local dev unblocked but the verification email gate will only succeed for
# operators who can read the server log. In production, set both.
RESEND_API_KEY=
EMAIL_FROM="Hitrapost <hello@hitrapost.co.uk>"

# Tawk.to live-chat webhook signing secret (set in Tawk dashboard:
# Administration → Webhooks → after creating the webhook, copy "Secret Key").
# When unset, signatures are not enforced (logged once on startup).
TAWK_WEBHOOK_SECRET=

# Email-to-lead inbound (SendGrid Inbound Parse).
#   EMAIL_INBOUND_DOMAIN — the subdomain SendGrid is parsing for, e.g.
#     leads.hitrapost.co.uk. Only mails whose recipient is on this
#     domain are accepted. Leave empty to disable the domain check.
#   EMAIL_INBOUND_SECRET — optional shared secret; when set, SendGrid
#     must include ?key=<secret> in the parse URL or we 401. Recommended
#     for production. Generate with:
#       node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
EMAIL_INBOUND_DOMAIN=leads.hitrapost.co.uk
EMAIL_INBOUND_SECRET=
